{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/career-planning/review_decision.schema.json",
  "title": "Human Review Decision Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "related_verdict_id",
    "opportunity_id",
    "decided_by",
    "human_confirmed",
    "decision",
    "rationale",
    "approved_opportunity_creation",
    "strategy_change",
    "external_action",
    "message_send",
    "next_steps",
    "audit_notes",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "2026-06-week3" },
    "review_id": { "type": "string", "minLength": 1 },
    "related_verdict_id": { "type": "string", "minLength": 1 },
    "opportunity_id": { "type": "string", "minLength": 1 },
    "decided_by": { "type": "string", "enum": ["human", "reviewer"] },
    "human_confirmed": { "type": "boolean", "const": true },
    "decision": {
      "type": "string",
      "enum": ["advance", "reject", "archive", "hold", "needs_more_info", "revise_strategy_draft_only"]
    },
    "rationale": { "type": "string", "minLength": 1 },
    "approved_opportunity_creation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created", "reason"],
      "properties": {
        "created": { "type": "boolean" },
        "reason": { "type": "string" }
      }
    },
    "strategy_change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["applied", "human_confirmed"],
      "properties": {
        "applied": { "type": "boolean" },
        "human_confirmed": { "type": "boolean", "const": true }
      }
    },
    "external_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["performed", "description"],
      "properties": {
        "performed": { "type": "boolean", "const": false },
        "description": { "type": "string" }
      }
    },
    "message_send": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sent", "description"],
      "properties": {
        "sent": { "type": "boolean", "const": false },
        "description": { "type": "string" }
      }
    },
    "next_steps": { "type": "array", "items": { "type": "string" } },
    "audit_notes": { "type": "array", "items": { "type": "string" } },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
